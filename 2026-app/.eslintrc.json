{
  "root": true,
  "extends": [
    "expo"
  ],
  "parserOptions": {
    "ecmaVersion": 2023,
    "sourceType": "module"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2023": true
  },
  "ignorePatterns": [
    "node_modules/",
    "babel.config.js",
    "metro.config.js",
    "jest.config.js",
    "dist/",
    "build/",
    ".expo/",
    "expo-env.d.ts"
  ],
  "rules": {
    "no-console": [
      "warn",
      {
        "allow": ["warn", "error"]
      }
    ],
    "prefer-const": "warn",
    "no-var": "error",
    "object-shorthand": "warn",
    "prefer-arrow-callback": "warn"
  }
}
