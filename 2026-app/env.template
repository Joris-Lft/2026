# ============================================
# Configuration Airtable
# ============================================
# 
# Récupérez ces valeurs depuis votre base Airtable :
# - Base ID : Trouvez-le dans l'URL de votre base Airtable
#   Exemple : https://airtable.com/appXXXXXXXXXXXXXX/...
# - API Key : Générez-la dans Account Settings > Developer options
#   https://airtable.com/account
#
# Pour utiliser ce fichier :
# 1. Copiez ce fichier vers .env.local : cp env.template .env.local
# 2. Remplissez les valeurs ci-dessous avec vos identifiants Airtable

# Base ID de votre base Airtable
# Format : appXXXXXXXXXXXXXX
EXPO_PUBLIC_AIRTABLE_BASE_ID=

# Clé API Airtable
# Format : patXXXXXXXXXXXXXX
EXPO_PUBLIC_AIRTABLE_API_KEY=

# Nom de la table contenant les utilisateurs
# Par défaut : Users
EXPO_PUBLIC_AIRTABLE_TABLE_NAME=Users

# Nom du champ email dans votre table Airtable
# Par défaut : Email
EXPO_PUBLIC_AIRTABLE_EMAIL_FIELD=Email

# Nom du champ mot de passe dans votre table Airtable
# Par défaut : Password
EXPO_PUBLIC_AIRTABLE_PASSWORD_FIELD=Password

# ============================================
# Configuration Table Habits
# ============================================
# 
# Nom de la table contenant les habits
# Par défaut : Habits
EXPO_PUBLIC_AIRTABLE_HABITS_TABLE_NAME=Habits

# Nom du champ user_id dans votre table Habits
# Par défaut : user_id
EXPO_PUBLIC_AIRTABLE_HABITS_USER_ID_FIELD=user_id

# Nom du champ name dans votre table Habits
# Par défaut : name
EXPO_PUBLIC_AIRTABLE_HABITS_NAME_FIELD=name

# Nom du champ frequency dans votre table Habits
# Par défaut : frequency
EXPO_PUBLIC_AIRTABLE_HABITS_FREQUENCY_FIELD=frequency

# ============================================
# Sécurité - Hachage des mots de passe
# ============================================
# 
# IMPORTANT : Changez cette valeur par une chaîne aléatoire et secrète
# Ce salt est utilisé pour hasher les mots de passe avant de les stocker
# 
# Pour générer un salt sécurisé, vous pouvez utiliser :
# - En ligne de commande : openssl rand -hex 32
# - Ou utilisez un générateur de chaînes aléatoires
# 
# ⚠️ NE PARTAGEZ JAMAIS cette valeur et ne la commitez pas dans Git

# Salt pour le hachage des mots de passe
EXPO_PUBLIC_PASSWORD_SALT=

