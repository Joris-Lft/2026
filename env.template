# ============================================
# Configuration Airtable
# ============================================
#
# Pour utiliser ce fichier :
# 1. Copiez ce fichier vers .env : cp env.template .env
# 2. Remplissez les valeurs ci-dessous avec vos identifiants Airtable

# Base ID de votre base Airtable
VITE_AIRTABLE_BASE_ID=

# Clé API Airtable
VITE_AIRTABLE_API_KEY=

# Nom de la table contenant les utilisateurs
VITE_AIRTABLE_TABLE_NAME=Users

# Nom du champ email dans votre table Airtable
VITE_AIRTABLE_EMAIL_FIELD=email

# Nom du champ mot de passe dans votre table Airtable
VITE_AIRTABLE_PASSWORD_FIELD=Password

# Champs de préférences de navigation (checkbox, cochés par défaut)
VITE_AIRTABLE_SHOW_HABITS_FIELD=show_habits
VITE_AIRTABLE_SHOW_MEASURES_FIELD=show_measures

# ============================================
# Configuration Table Habits
# ============================================

VITE_AIRTABLE_HABITS_TABLE_NAME=Habits
VITE_AIRTABLE_HABITS_USER_ID_FIELD=user_id
VITE_AIRTABLE_HABITS_NAME_FIELD=name
VITE_AIRTABLE_HABITS_FREQUENCY_FIELD=frequency
VITE_AIRTABLE_HABITS_CREATED_AT_FIELD=created_at

# ============================================
# Configuration Table HabitsLogs
# ============================================

VITE_AIRTABLE_HABITS_LOGS_TABLE_NAME=HabitsLogs
VITE_AIRTABLE_HABITS_LOGS_HABIT_ID_FIELD=habit_id
VITE_AIRTABLE_HABITS_LOGS_USER_ID_FIELD=user_id
VITE_AIRTABLE_HABITS_LOGS_COMPLETED_AT_FIELD=completed_at
VITE_AIRTABLE_HABITS_LOGS_FREQUENCY_FIELD=frequency
VITE_AIRTABLE_HABITS_LOGS_PERIOD_FIELD=period

# ============================================
# Configuration Table Measures
# ============================================

VITE_AIRTABLE_MEASURES_TABLE_NAME=Measures
VITE_AIRTABLE_MEASURES_MEASURE_ID_FIELD=measure_id
VITE_AIRTABLE_MEASURES_USER_ID_FIELD=user_id
VITE_AIRTABLE_MEASURES_DATE_FIELD=date
VITE_AIRTABLE_MEASURES_WEIGHT_FIELD=weight
VITE_AIRTABLE_MEASURES_ARM_FIELD=arm
VITE_AIRTABLE_MEASURES_BUST_FIELD=bust
VITE_AIRTABLE_MEASURES_WAIST_FIELD=waist
VITE_AIRTABLE_MEASURES_HIP_FIELD=hip
VITE_AIRTABLE_MEASURES_THIGH_FIELD=thigh

# ============================================
# Configuration Table Notes
# ============================================

VITE_AIRTABLE_NOTES_TABLE_NAME=Notes
VITE_AIRTABLE_NOTES_ID_FIELD=id
VITE_AIRTABLE_NOTES_CONTENT_FIELD=Notes
VITE_AIRTABLE_NOTES_ASSIGNEES_FIELD=Assignees
VITE_AIRTABLE_NOTES_STATUS_FIELD=Status
VITE_AIRTABLE_NOTES_ATTACHMENTS_FIELD=Attachments
VITE_AIRTABLE_NOTES_CREATED_AT_FIELD=created_at

# ============================================
# Sécurité - Hachage des mots de passe
# ============================================

VITE_PASSWORD_SALT=

# Optionnel — hébergement permanent des images de notes (sinon upload temporaire 24h)
# VITE_IMGBB_API_KEY=
